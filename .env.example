# ============================================
# Microsoft Graph MCP Server - 環境変数設定
# ============================================

# ── 認証モード（必須）──
# "graph_token"         : 各ユーザーが Bearer Token で Microsoft Graph アクセストークンを渡す（デフォルト）
# "client_credentials"  : Azure AD アプリのクライアント資格情報で認証（サーバー対サーバー）
# "api_key"             : MCP_API_KEY でサーバーへのアクセスを制限 + 環境変数のクライアント資格情報を使用
AUTH_MODE=graph_token

# ── Azure AD アプリ設定 ──
# AUTH_MODE=client_credentials または api_key の場合は必須
# Azure Portal > Entra ID > アプリの登録 で作成
# MICROSOFT_CLIENT_ID=your-application-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_TENANT_ID=your-tenant-id

# ── MCP API キー ──
# AUTH_MODE=api_key の場合は必須
# 任意の文字列を設定し、MCP クライアントの Bearer Token としてこの値を指定
# MCP_API_KEY=your-secret-api-key-here
