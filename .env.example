# ============================================
# Microsoft Graph MCP Server - 環境変数設定
# ============================================

# ── 管理パスワード (必須) ──
# /auth ページのアクセス保護用。自分で決めた任意の文字列。
ADMIN_SECRET=your-admin-password-here

# ── Azure AD アプリ設定 (必須) ──
# Azure Portal > Microsoft Entra ID > アプリの登録 で作成
MICROSOFT_CLIENT_ID=your-application-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-directory-tenant-id

# ── トークン暗号化キー (必須) ──
# refresh_token を Redis に保存する際の暗号化キー。
# 以下のコマンドで生成:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-random-hex-string-here

# ── 以下は自動設定 ──
# Vercel Marketplace の Upstash Redis 統合で自動設定:
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx
#
# Vercel が自動設定:
# CRON_SECRET=xxx
