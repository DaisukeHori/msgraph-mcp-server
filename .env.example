# ============================================
# Microsoft Graph MCP Server - 環境変数設定
# ============================================
#
# 「本人として」操作するか「管理者アプリ」として操作するかを選択します。
# ほとんどの場合 delegated（本人）が正しい選択です。

# ── 認証モード ──
#
# "delegated" (デフォルト / ローカル向け):
#   → 本人としてサインイン。初回のみブラウザで認証。
#   → /me/ エンドポイントで自分のメール・予定・ファイルを操作。
#   → MICROSOFT_CLIENT_ID と MICROSOFT_TENANT_ID が必要。
#   → クライアントシークレットは不要（パブリッククライアント）。
#
# "token" (Vercel 向け):
#   → 本人のアクセストークンを Bearer Token で渡す。
#   → /me/ エンドポイントが使え、本人としてアクセス。
#   → サーバー側に Azure AD 設定は不要。
#
# "client_credentials" (管理者/自動化向け):
#   → アプリとして認証。全ユーザーのデータにアクセス可能。
#   → /me/ は使えない。/users/{userId}/ が必要。
#   → MICROSOFT_CLIENT_ID, MICROSOFT_CLIENT_SECRET, MICROSOFT_TENANT_ID が全て必要。
#
AUTH_MODE=delegated

# ── Azure AD アプリ設定 ──
# Azure Portal > Microsoft Entra ID > アプリの登録 で作成
#
# delegated モード: CLIENT_ID と TENANT_ID が必要（シークレット不要）
# client_credentials モード: 3つ全て必要
#
MICROSOFT_CLIENT_ID=your-application-client-id
MICROSOFT_TENANT_ID=your-directory-tenant-id
# MICROSOFT_CLIENT_SECRET=your-client-secret  # client_credentials の場合のみ
